# =============================================================================
# Borough — Brooklyn Rental Market Intelligence
# Copy this file to .env and fill in the values.
#
# ALL API keys below are FREE. Keys are optional but improve rate limits.
# =============================================================================

# --- Government / public API keys (all free) ---
# FRED (Federal Reserve): https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Census Bureau: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
# Bureau of Labor Statistics: https://www.bls.gov/developers/
BLS_API_KEY=
# NYC Open Data: https://data.cityofnewyork.us/profile/edit/developer_settings
NYC_OPEN_DATA_APP_TOKEN=

# --- S3 (Bronze ingestion bucket) ---
# Leave access/secret blank to use default AWS credential chain (env, ~/.aws/credentials, IAM role)
BRONZE_S3_REGION=us-east-1
BRONZE_S3_BUCKET=borough-bronze
BRONZE_S3_ACCESS_KEY=
BRONZE_S3_SECRET_KEY=

# --- Postgres (async connection via asyncpg) ---
POSTGRES_DSN=

# --- Redis (Celery broker + result backend) ---
REDIS_URL=
